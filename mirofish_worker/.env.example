# Copy to .env. The worker reads these on startup (via python-dotenv).

# Simulation engine: `swarm` (custom shopper-agent orchestration, default) or
# `mirofish` (legacy OASIS CLI, kept as an instant rollback).
SHOPSIM_ENGINE=swarm

# --- swarm engine ----------------------------------------------------------
# Full-store mode gives each product AGENTS_PER_PRODUCT agents, capped at
# MAX_EASY_AGENT total (so ~10 products at full fidelity per run). A/B mode
# uses AB_AGENT_COUNT agents that evaluate variant A and B paired.
AGENTS_PER_PRODUCT=10
MAX_EASY_AGENT=100
AB_AGENT_COUNT=10
# Max simultaneous Gemini calls across a run.
EASY_CONCURRENCY=12
# Heavy model grasps the store / designs segments / writes the report;
# the cheap model powers the parallel easy-agent swarm.
BOSS_MODEL=gemini-2.5-pro
EASY_MODEL=gemini-2.5-flash
# Global per-run wall-clock budget for a swarm run (seconds).
SWARM_TIMEOUT=900

# --- legacy MiroFish engine (only used when SHOPSIM_ENGINE=mirofish) --------
# MiroFish LLM backend. This fork adds `gemini-api` alongside claude-cli/codex-cli.
LLM_PROVIDER=gemini-api

# Gemini API — used by BOTH MiroFish simulations and the /suggest endpoint.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Set to 1 to skip the real `mirofish` CLI and return a deterministic fixture
# verdict (no LLM calls). Great for local dev / wiring the app end-to-end.
MIROFISH_MOCK=0

# Path/command to the mirofish executable.
#  - On Railway: DO NOT set this. The Dockerfile already points it at the CLI
#    built into the image (/opt/mirofish-cli/.venv/bin/mirofish). Setting it here
#    overrides that and breaks real runs ("No such file or directory: 'mirofish'").
#  - Locally: point at your clone's venv, e.g. (Windows)
#    MIROFISH_BIN=C:/path/to/mirofish-cli/.venv/Scripts/mirofish.exe
# MIROFISH_BIN=

# Simulation rounds per run (lower = faster/cheaper). Default 6.
MIROFISH_MAX_ROUNDS=4

# Where run artifacts are written.
RUNS_DIR=./runs

# Host/port (Railway sets $PORT automatically).
HOST=0.0.0.0
PORT=8800

# Shared secret. When set, every protected route requires the X-ShopSim-Auth
# header. Set the SAME value here and as BACKEND_SECRET on the Shopify app.
# Leave blank for local dev. Generate one with: openssl rand -hex 32
BACKEND_SECRET=
